<!-- LANDING PAGE - Shown first or if skipStartup is false and profile is complete -->
<div id="landing-page" class="day-content hidden">
    <h2 class="text-4xl font-black text-[#03254E] mb-6">Welcome!</h2>
    <p class="text-lg text-gray-700 mb-10">Start your fitness journey or continue your progress.</p>
    <button onclick="enterTracker()" class="w-2/3 py-4 bg-[#01B492] text-white text-xl font-bold rounded-lg shadow-lg hover:bg-[#009e7d] transition duration-150 transform hover:scale-105">
        ENTER TRACKER
    </button>
    <div class="mt-8 pt-4 border-t w-2/3 flex justify-center items-center space-x-2">
        <input type="checkbox" id="skip-landing-checkbox" class="text-[#00A6FB] focus:ring-[#00A6FB]">
        <label for="skip-landing-checkbox" class="text-sm font-medium text-gray-600">Bypass this page next time</label>
    </div>
</div>
